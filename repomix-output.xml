    """
    repo_path = os.getenv("TI_REPO_PATH", "/home/kali/Desktop/misp/repository")
    inventory = os.getenv("ANSIBLE_INVENTORY", "ansible/inventory.ini")
    
    is_local_mock = os.getenv("IS_LOCAL_MOCK", "true").lower() in ("true", "1")
    
    if is_local_mock:
