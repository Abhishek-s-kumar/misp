                            }
                        }
                        if (toolId === 'deploy' && data.deploy_tag) {
                            setRollbackTag(data.deploy_tag);
                        }
                    } else {
                        addLog('error', `Tool failed. Status: ${data.status || 'unknown error'}`, data);
                    }

