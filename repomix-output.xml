                                />
                            </div>

                            <div className="form-group">
                                <label>Ansible Host IP</label>
                                <input 
                                    type="text" 
                                    value={hostIp} 
                                    onChange={(e) => { setHostIp(e.target.value); setSelectedPreset(''); }} 
                                />
                            </div>

                            <div className="form-row">
                                <div className="form-group">
                                    <label>SSH User</label>
