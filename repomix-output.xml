<file path="DaC/ansible/deploy_rules.yml">
---
- name: Deploy Detection Rules
  hosts: wazuh_managers
  serial: 1
  vars:
    git_tag_name: "last_known_good"
  tasks:
    - name: Set local mock directory paths if mock enabled
      set_fact:
        target_rules_dir: "{{ playbook_dir }}/../mock_wazuh/etc/rules"
        target_yara_dir: "{{ playbook_dir }}/../mock_wazuh/opt/yara-rules"
        target_wazuh_bin: "/bin/true"
      when: is_local_mock | bool

    - name: Set actual directory paths if mock disabled
      set_fact:
        target_rules_dir: "{{ wazuh_rules_dir }}"
        target_yara_dir: "{{ yara_rules_dir }}"
        target_wazuh_bin: "{{ wazuh_bin }}"
      when: not (is_local_mock | bool)

    - name: Ensure target rule folders exist
      file:
        path: "{{ item }}"
        state: directory
        owner: "{{ omit if (is_local_mock | bool) else wazuh_file_owner }}"
        group: "{{ omit if (is_local_mock | bool) else wazuh_file_group }}"
        mode: "{{ wazuh_dir_mode }}"
      loop:
        - "{{ target_rules_dir }}"
        - "{{ target_yara_dir }}"

    - name: Run baseline configuration check
      command: "{{ target_wazuh_bin }}/wazuh-analysisd -t"
      register: baseline_check
      ignore_errors: yes
      when: not (is_local_mock | bool)

    - name: Fail if baseline config is invalid
      fail:
        msg: "Baseline wazuh configuration test failed before deployment. Aborting."
      when: not (is_local_mock | bool) and baseline_check.rc != 0

    - name: Create manager-side backup directory
      file:
        path: /var/ossec/etc/rules_backup
        state: directory
        mode: 0750
      when: not (is_local_mock | bool)

    - name: Check if existing local_rules.xml exists
      stat:
        path: "{{ target_rules_dir }}/local_rules.xml"
      register: wazuh_local_rules_stat
      when: not (is_local_mock | bool)

    - name: Back up existing local_rules.xml
      copy:
        src: "{{ target_rules_dir }}/local_rules.xml"
        dest: /var/ossec/etc/rules_backup/local_rules.xml.bak
        remote_src: yes
      when: not (is_local_mock | bool) and wazuh_local_rules_stat.stat.exists

    - name: Back up existing YARA rules as archive
      archive:
        path: "{{ target_yara_dir }}"
        dest: /var/ossec/etc/rules_backup/yara_rules_backup.tar.gz
        format: gz
      ignore_errors: yes
      when: not (is_local_mock | bool)

    - name: Sync compiled Wazuh rules file to managers
      copy:
        src: ../generated/local_rules.xml
        dest: "{{ target_rules_dir }}/local_rules.xml"
        owner: "{{ omit if (is_local_mock | bool) else wazuh_file_owner }}"
        group: "{{ omit if (is_local_mock | bool) else wazuh_file_group }}"
        mode: "{{ wazuh_file_mode }}"
      register: copy_wazuh_rules

    - name: Sync YARA rules to managers
      copy:
        src: ../rules/yara/
        dest: "{{ target_yara_dir }}/"
        owner: "{{ omit if (is_local_mock | bool) else wazuh_file_owner }}"
        group: "{{ omit if (is_local_mock | bool) else wazuh_file_group }}"
        mode: "{{ wazuh_file_mode }}"
      register: copy_yara_rules

    - name: Validate configuration after deploying rules
      command: "{{ target_wazuh_bin }}/wazuh-analysisd -t"
      register: post_deploy_check
      ignore_errors: yes
      when: not (is_local_mock | bool) and (copy_wazuh_rules.changed or copy_yara_rules.changed)

    - name: Revert rule changes and restart if configuration check fails
      block:
        - name: Warn about validation failure
          debug:
            msg: "Validation check failed! Reverting rules to manager-side backups and Git tag: {{ git_tag_name }}"

        - name: Restore local_rules.xml from manager backup
          copy:
            src: /var/ossec/etc/rules_backup/local_rules.xml.bak
            dest: "{{ target_rules_dir }}/local_rules.xml"
            remote_src: yes
          ignore_errors: yes
          when: not (is_local_mock | bool) and wazuh_local_rules_stat.stat.exists

        - name: Restore YARA rules from manager backup archive
          unarchive:
            src: /var/ossec/etc/rules_backup/yara_rules_backup.tar.gz
            dest: "{{ target_yara_dir }}/"
            remote_src: yes
          ignore_errors: yes
          when: not (is_local_mock | bool)

        - name: Check out approved rules from Git tag on controller
          command: "git checkout {{ git_tag_name }} -- rules/ generated/"
          delegate_to: localhost
          register: git_revert
          ignore_errors: yes

        - name: Redeploy last known good Wazuh rules from controller git
          copy:
            src: ../generated/local_rules.xml
            dest: "{{ target_rules_dir }}/local_rules.xml"
            owner: "{{ omit if (is_local_mock | bool) else wazuh_file_owner }}"
            group: "{{ omit if (is_local_mock | bool) else wazuh_file_group }}"
            mode: "{{ wazuh_file_mode }}"
          ignore_errors: yes

        - name: Redeploy last known good YARA rules from controller git
          copy:
            src: ../rules/yara/
            dest: "{{ target_yara_dir }}/"
            owner: "{{ omit if (is_local_mock | bool) else wazuh_file_owner }}"
            group: "{{ omit if (is_local_mock | bool) else wazuh_file_group }}"
            mode: "{{ wazuh_file_mode }}"
          ignore_errors: yes

        - name: Fail deployment task
          fail:
            msg: "Wazuh rules validation failed. Changes have been rolled back to manager-side backups."
      when: not (is_local_mock | bool) and (copy_wazuh_rules.changed or copy_yara_rules.changed) and (post_deploy_check.rc is defined and post_deploy_check.rc != 0)

    - name: Restart Wazuh manager if changes were made
      command: "{{ target_wazuh_bin }}/wazuh-control restart"
      register: wazuh_restart
      when: not (is_local_mock | bool) and (copy_wazuh_rules.changed or copy_yara_rules.changed)

    - name: Verify Wazuh service is running after restart
      command: "{{ target_wazuh_bin }}/wazuh-control status"
      register: wazuh_status
      retries: 3
      delay: 5
      until: wazuh_status.rc == 0
      when: not (is_local_mock | bool) and (copy_wazuh_rules.changed or copy_yara_rules.changed)
</file>

