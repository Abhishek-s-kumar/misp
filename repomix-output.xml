                    user: 'waserver',
                    keyPath: ""
                },
                {
                    id: 'stage',
                    name: 'Staging Wazuh Manager',
                    ip: '192.168.10.160',
                    user: 'waserver',
                    keyPath: ""
                }
            ];

            // Host State
