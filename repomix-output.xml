                        rollback: { url: "/rollback", body: { tag: opts.tag,        host_name: activeHost.name, host_ip: activeHost.ip, ssh_user: activeHost.user, ssh_key_path: activeHost.keyPath } },
                        status:   { url: "/status",   body: { manager_host: activeHost.name, host_ip: activeHost.ip, ssh_user: activeHost.user, ssh_key_path: activeHost.keyPath } },
                    };

                    const { url, body } = endpointMap[toolId];
                    
                    addLog('info', `HTTP POST ${url}`, body);

                    const res = await fetch(url, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(body)
                    });

                    if (!res.ok) {
                        throw new Error(`Server returned HTTP ${res.status}: ${res.statusText}`);
                    }

                    const data = await res.json();
                    
                    // Interpret output status
                    const isSuccess = data.status === "ok" || data.status === "committed" || data.status === "no_changes" || data.valid_count !== undefined || data.wazuh_running !== undefined;
                    
                    if (isSuccess) {
                        addLog('success', `Tool completed successfully.`, data);
                        
                        // If it is status query, logs can display wazuh status specifically
                        if (toolId === 'status') {
                            addLog('success', `Wazuh service: ${data.wazuh_running ? 'RUNNING' : 'STOPPED'} | Yara rules: ${data.yara_rules_count} | Wazuh rules: ${data.wazuh_rules_count}`);
                            if (data.last_deployment_tag) {
