# MISP Connection Details
MISP_URL=https://misp.cyberrange.local
MISP_API_KEY=your_misp_api_key_here
MISP_VERIFY_SSL=false

# Git Repository Configuration
# Path to the Git repository acting as the artifact store
TI_REPO_PATH=/home/kali/Desktop/misp/repository
GIT_REMOTE=origin
GIT_BRANCH=main

# Ansible Configuration
ANSIBLE_INVENTORY=/home/kali/Desktop/misp/ansible/inventory.ini
ANSIBLE_VAULT_PASSWORD_FILE=/home/kali/Desktop/misp/.vault_pass

# Provider selection
MISP_PROVIDER=mock        # "mock" or "real"

# MCP/Python tool mode (controls Python MCP tools)
IS_LOCAL_MOCK=true        # "true" for local dev, "false" for real Wazuh

# Scheduler
ENABLE_SCHEDULER=false
SCHEDULER_INTERVAL_HOURS=1


# GitHub external rule sources (pinned ref — nothing new pulls until you bump these manually)
GITHUB_TOKEN=
GITHUB_RULE_TAGS=
GITHUB_SIGMA_REPO=SigmaHQ/sigma
GITHUB_SIGMA_REF=master
GITHUB_SIGMA_PATH=rules/windows/process_creation
GITHUB_YARA_REPO=Yara-Rules/rules
GITHUB_YARA_REF=master
GITHUB_YARA_PATH=malware

# Host UID/GID the container should run as, so files written to bind-mounted
# volumes (repository/.git etc) are owned by the host user, not root.
# Run `id -u` / `id -g` on the target machine to get the right values.
HOST_UID=1000
HOST_GID=1000
